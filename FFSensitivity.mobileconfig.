    <script>
        function calculateSensitivity() {
            const brand = document.getElementById('brand').value;
            const screenSize = document.getElementById('screenSize').value;
            const refreshRate = document.getElementById('refreshRate').value;
            const handSize = document.getElementById('handSize').value;

            if (!brand || !screenSize || !refreshRate || !handSize) {
                alert('Vui lòng chọn đầy đủ tất cả thông số để tính toán chính xác!');
                return;
            }

            const size = parseFloat(screenSize);
            const hz = parseInt(refreshRate);
            
            // Hệ số nền tảng cảm ứng theo hãng
            const brandFactors = {
                'apple': { name: 'Apple iPhone', base: 1.0, touch: 1.0, delay: 0 },
                'samsung': { name: 'Samsung Galaxy', base: 0.95, touch: 1.05, delay: 2 },
                'xiaomi': { name: 'Xiaomi / Redmi / POCO', base: 0.90, touch: 1.08, delay: 3 },
                'oppo': { name: 'OPPO', base: 0.88, touch: 1.10, delay: 4 },
                'vivo': { name: 'Vivo', base: 0.87, touch: 1.10, delay: 4 },
                'realme': { name: 'Realme', base: 0.89, touch: 1.09, delay: 3 },
                'oneplus': { name: 'OnePlus', base: 0.93, touch: 1.04, delay: 2 },
                'huawei': { name: 'Huawei', base: 0.86, touch: 1.12, delay: 5 },
                'asus': { name: 'ASUS ROG Phone', base: 1.05, touch: 0.95, delay: 0 },
                'nubia': { name: 'Nubia Red Magic', base: 1.08, touch: 0.92, delay: 0 },
                'other': { name: 'Thiết bị khác', base: 0.90, touch: 1.08, delay: 3 }
            };

            const bf = brandFactors[brand];
            
            // Công thức tính độ nhạy Camera
            // Camera = (60 / kích thước màn hình) * (60 / Hz) * hệ số nền tảng * hệ số ngón chơi * 100
            let sizeFactor = 6.0 / size; // Màn hình nhỏ hơn -> cần độ nhạy thấp hơn để kiểm soát
            let hzFactor = 60.0 / hz; // Hz cao hơn -> giảm độ nhạy vì cảm ứng mượt hơn
            let handFactor = 1.0;
            if (handSize.includes('2-small')) handFactor = 0.85;
            else if (handSize.includes('2-large')) handFactor = 0.90;
            else if (handSize.includes('3')) handFactor = 0.95;
            else if (handSize.includes('4')) handFactor = 1.05;
            else if (handSize.includes('5')) handFactor = 1.15;

            // Công thức cốt lõi
            let cameraSens = Math.round((sizeFactor * hzFactor * bf.base * handFactor * 95));
            // Giới hạn trong khoảng 30-100
            cameraSens = Math.max(30, Math.min(100, cameraSens));

            // ADS = Camera * 0.75 (luôn thấp hơn để kiểm soát khi ngắm)
            let adsSens = Math.round(cameraSens * 0.75);
            adsSens = Math.max(20, Math.min(95, adsSens));

            // Red Dot = ADS * 0.85
            let redDotSens = Math.round(adsSens * 0.85);
            redDotSens = Math.max(15, Math.min(90, redDotSens));

            // Ống ngắm x2 = ADS * 0.65
            let sens2x = Math.round(adsSens * 0.65);
            sens2x = Math.max(10, Math.min(80, sens2x));

            // Ống ngắm x4 = ADS * 0.45
            let sens4x = Math.round(adsSens * 0.45);
            sens4x = Math.max(5, Math.min(60, sens4x));

            // Gyro: phụ thuộc vào tần số quét và kích thước màn hình
            let gyroBase = Math.round((size * 15) + (hz * 0.2));
            gyroBase = Math.max(30, Math.min(90, gyroBase));

            // Điều chỉnh dựa trên độ trễ cảm ứng của hãng
            let delayAdjust = bf.delay * 2;
            cameraSens = Math.round(cameraSens + delayAdjust);
            adsSens = Math.round(adsSens + delayAdjust * 0.8);

            // Hiển thị kết quả
            document.getElementById('resultTitle').innerHTML = 
                '📱 ' + bf.name + ' | ' + screenSize + '" | ' + hz + 'Hz | ' + 
                (handSize.includes('2') ? '2 Ngón' : handSize.includes('3') ? '3 Ngón' : handSize.includes('4') ? '4 Ngón' : '5+ Ngón');
            
            document.getElementById('sensCamera').textContent = cameraSens + '%';
            document.getElementById('sensADS').textContent = adsSens + '%';
            document.getElementById('sensRedDot').textContent = redDotSens + '%';
            document.getElementById('sens2x').textContent = sens2x + '%';
            document.getElementById('sens4x').textContent = sens4x + '%';
            document.getElementById('sensGyro').textContent = gyroBase + '%';
            
            let note = '💡 Mẹo: ';
            if (hz >= 120) {
                note += 'Máy bạn có tần số quét cao, tận dụng Gyro để tối ưu phản xạ. ';
            }
            if (size >= 6.7) {
                note += 'Màn hình lớn, nên chơi 4-5 ngón để thao tác nhanh hơn. ';
            }
            if (brand === 'apple') {
                note += 'iPhone có cảm ứng rất nhạy, giảm thêm 5% nếu thấy trượt quá. ';
            }
            if (brand === 'xiaomi' || brand === 'oppo' || brand === 'vivo' || brand === 'realme') {
                note += 'Máy Android tầm trung có độ trễ cảm ứng nhẹ, tăng Gyro bù trừ. ';
            }
            note += 'Vào Phòng tập kiểm tra và tinh chỉnh ±5% cho phù hợp tay.';
            document.getElementById('noteText').textContent = note;

            document.getElementById('resultCard').classList.add('show');
            document.getElementById('resultCard').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
